      "name": "01. Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "// Verificamos que todo salió bien\r",
              "pm.test(\"Login exitoso\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.expect(jsonData).to.have.property('token');\r",
              "});\r",
              "\r",
              "// 👇 EL CAMBIO MÁGICO: collectionVariables\r",
              "// Esto guarda el token DENTRO del archivo de la colección\r",
              "pm.collectionVariables.set(\"token_seguridad\", jsonData.token); \r",
              "\r",
              "console.log(\"Token guardado:\", jsonData.token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
